doctype html
html(lang="es")
    head
        title Detalle de Obra
    body
        div.container.mt-5
            h1 Detalle de: #{obra.nombre}
            ul.list-group
                li.list-group-item ID: #{obra.id}
                li.list-group-item Ubicación: #{obra.ubicacion}
                li.list-group-item Presupuesto: USD #{obra.presupuesto}
            a.btn.btn-primary.mt-3(href="/") Volver al inicio
